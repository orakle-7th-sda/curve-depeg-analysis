# Dune Analytics API key
# Get yours at https://dune.com → Settings → API Keys
DUNE_API_KEY=your_dune_api_key_here

# Dune query IDs — create queries using the SQL in src/fetch_dune.py,
# then paste the numeric ID from the URL (dune.com/queries/XXXXXXX)
DUNE_QUERY_ID_SVB=0        # Curve 3Pool  · SVB event  2023-03-09 ~ 03-14
DUNE_QUERY_ID_USDT=0       # Curve 3Pool  · USDT event 2023-06-14 ~ 06-16
DUNE_QUERY_ID_UNI_SVB=0    # Uniswap V3   · SVB event
DUNE_QUERY_ID_UNI_USDT=0   # Uniswap V3   · USDT event

# Ethereum RPC URL — for real-time Curve 3Pool monitoring (monitor_curve.py)
# Free options: Alchemy (https://dashboard.alchemy.com) or Infura
ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/your_api_key_here
